# Copy this file to .env.local and fill in your own values.
# .env.local is gitignored — never commit real secrets.

# ─── Database (required) ───────────────────────────────────────────────
# A standard Postgres connection string. Works with any Postgres
# provider, but the easiest free option is Neon (neon.tech):
#   1. Sign up (no credit card)
#   2. Create a project
#   3. Copy the connection string it gives you — it already includes
#      sslmode=require, which this app expects
# Free tier: 0.5 GB storage, permanent (not a trial), scales to zero
# when idle. Plenty for a small shop's users/orders/stock tables.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── Payments ────────────────────────────────────────────────────────
# UPI-only path (no gateway account needed). Set your own UPI VPA here.
NEXT_PUBLIC_UPI_ID=yourvpa@upi
NEXT_PUBLIC_MERCHANT_NAME=tandh studio

# Razorpay (optional, but recommended — gives fully automatic payment
# confirmation, including for UPI, with no manual reference-number step).
# Get these from https://dashboard.razorpay.com/app/keys
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# COD is permanently disabled — there is no environment variable for it.

# ─── Authentication (required — checkout is gated behind login) ───────
# Any long random string. Generate one with: openssl rand -base64 32
NEXTAUTH_SECRET=
# Must match the URL you're running the site on.
NEXTAUTH_URL=http://localhost:3000
# Lets login work correctly from any device/IP (e.g. your phone over
# LAN), not just the exact host in NEXTAUTH_URL above. The app sets
# this to "true" by default even if left blank here — see the comment
# in src/lib/auth.ts for the security note on what this trusts.
AUTH_TRUST_HOST=true

# Google sign-in (optional). Leave blank to only offer email/password
# login. See the setup guide for how to create these in Google Cloud
# Console — you'll need to add this Authorized redirect URI there:
#   http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Admin CSV export endpoints (optional) ────────────────────────────
# data/users.csv and data/orders.csv are kept up to date automatically
# and can just be opened directly from the /data folder. Set this only
# if you also want to download them remotely via
# /api/admin/export/users?key=... and /api/admin/export/orders?key=...
ADMIN_EXPORT_KEY=
